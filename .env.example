# ---- Firebase web app config (from Firebase console > Project settings > your web app) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- The admin (you). Lowercase email. ----
NEXT_PUBLIC_ADMIN_EMAIL=guy_te3@hotmail.com

# ---- Secret iCal URL of the trip's Google Calendar (server-side only, never NEXT_PUBLIC) ----
# Google Calendar > Settings for that calendar > "Secret address in iCal format"
TRIP_ICAL_URL=

# Optional: token to protect the cron refresh endpoint
CRON_SECRET=

# ---- Gemini API key for AI place enrichment (server-side only, never NEXT_PUBLIC) ----
# Free tier is fine. Get one at https://aistudio.google.com/app/apikey
# Without it, /api/enrich returns 503 and the "Auto-fill" UI stays disabled.
GEMINI_API_KEY=
