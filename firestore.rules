rules_version = '2';

// Gooshie Travels — Firestore rules.
// If you share a Firebase project with other apps, merge the blocks below into
// your existing rules (keep your other collections) and make sure isAdmin()
// lists every admin email.
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && (
        request.auth.token.email.lower() == 'guy_te3@hotmail.com'
        || request.auth.token.email.lower() == 'maissis1987@gmail.com'
      );
    }
    // An approved member (any status doc that is approved) — for reads.
    function isMember() {
      return isAdmin() || (
        isAuth()
        && exists(/databases/$(database)/documents/members/$(request.auth.token.email.lower()))
        && get(/databases/$(database)/documents/members/$(request.auth.token.email.lower())).data.status == 'approved'
      );
    }
    function isEditor() {
      return isAdmin() || (
        isAuth()
        && exists(/databases/$(database)/documents/members/$(request.auth.token.email.lower()))
        && get(/databases/$(database)/documents/members/$(request.auth.token.email.lower())).data.role in ['editor', 'admin']
        && get(/databases/$(database)/documents/members/$(request.auth.token.email.lower())).data.status == 'approved'
      );
    }

    // Membership + roles.
    match /members/{email} {
      allow read: if isAdmin() || (isAuth() && request.auth.token.email.lower() == email);
      allow create: if isAdmin() || (
        isAuth()
        && request.auth.token.email.lower() == email
        && request.resource.data.status == 'pending'
        && request.resource.data.role == 'viewer'
      );
      allow update, delete: if isAdmin();
    }

    // The Database (all entities) — members read, editors write.
    match /entities/{id} {
      allow read: if isMember();
      allow write: if isEditor();
    }

    // Trips, cached itineraries, per-trip curation — members read, editors write.
    match /trips/{id} {
      allow read: if isMember();
      allow write: if isEditor();
    }
    match /tripItineraries/{id} {
      allow read: if isMember();
      allow write: if isEditor();
    }
    match /tripEntities/{tripId}/items/{entityId} {
      allow read: if isMember();
      allow write: if isEditor();
    }
    match /tripInstances/{tripId}/items/{instanceId} {
      allow read: if isMember();
      allow write: if isEditor();
    }
    // New itinerary model: app-owned slots + plan instances — members read, editors write.
    match /tripSlots/{tripId}/items/{slotId} {
      allow read: if isMember();
      allow write: if isEditor();
    }
    match /tripPlanInstances/{tripId}/items/{instanceId} {
      allow read: if isMember();
      allow write: if isEditor();
    }

    // Secret calendar URLs — editors only (never exposed to viewers).
    match /tripSecrets/{id} {
      allow read, write: if isEditor();
    }

    // Managed metadata (general-area list, seed marker, dismissed issues).
    match /meta/{doc} {
      allow read: if isMember();
      allow write: if isEditor();
    }

    // Public Trip Recaps — the curated, published snapshot. Anyone (no auth) can
    // read; only editors can write. The public /r/[slug] page renders via the
    // Admin SDK, so this public read only matters for any client-side reads.
    match /recaps/{slug} {
      allow read: if true;
      allow write: if isEditor();
    }

    // Comments on instances/appearances — any member can read and post; the
    // author or an admin can delete.
    match /comments/{id} {
      allow read: if isMember();
      allow create: if isMember()
        && request.resource.data.authorEmail == request.auth.token.email.lower();
      allow delete: if isAdmin()
        || (isAuth() && resource.data.authorEmail == request.auth.token.email.lower());
    }
  }
}
